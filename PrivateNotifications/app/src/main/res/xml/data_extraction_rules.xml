<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude sensitive data from cloud backup -->
        <exclude domain="sharedpref" path="PrivateNotificationsPrefs.xml"/>
    </cloud-backup>
    <device-transfer>
        <!-- Rules for device-to-device transfer -->
        <include domain="sharedpref" path="."/>
    </device-transfer>
</data-extraction-rules>
